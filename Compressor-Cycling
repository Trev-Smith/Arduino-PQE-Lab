  #include <Servo.h>

  #include <Servo.h>

  Servo myServo;  // create a servo object

  // Define the counter pin
  const int counterPin = 3;


  void setup() {
    myServo.attach(2);   // attach servo to pin 2
    pinMode(counterPin, OUTPUT); // set pin 3 as output for counter signal
    myServo.write(0);    // start at 0 degrees
  }

  void loop() {
    // Move to 100 degrees
    myServo.write(100);
    //delay (3000); //test line
    delay(130000);  // stay at 100° for 130 seconds (130,000 ms)

    // Move back to 0 degrees
    myServo.write(0);
    //delay(3000); //test line
    delay(99000); // stay at 0° for 108 sec (108,000 ms)

    // Increment counter
    digitalWrite(counterPin, HIGH);
    delay(100); // short pulse for external counter to register
    digitalWrite(counterPin, LOW);

    // Loop repeats automatically
  }
